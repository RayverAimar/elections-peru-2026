---
import { daysUntilElection } from '../lib/utils';

const days = daysUntilElection();
---

<footer class="border-t border-surface-300/30 bg-surface-50">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <div class="flex items-center gap-2 text-lg font-bold text-white">
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent">
            <span class="text-xs font-extrabold text-white">C</span>
          </div>
          Chasqui
        </div>
        <p class="mt-1 text-xs text-surface-500">Tu mensajero electoral</p>
        <p class="mt-3 text-sm leading-relaxed text-surface-600">
          Información electoral basada en datos oficiales del JNE.
          Sin afiliación política.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-surface-500">Navegación</h3>
        <ul class="mt-3 -ml-3 space-y-0.5 text-sm">
          <li><a href="/brujula" class="inline-block rounded-lg px-3 py-2 text-surface-600 transition hover:text-accent">Quiz Electoral</a></li>
          <li><a href="/candidatos" class="inline-block rounded-lg px-3 py-2 text-surface-600 transition hover:text-accent">Candidatos</a></li>
          <li><a href="/chat" class="inline-block rounded-lg px-3 py-2 text-surface-600 transition hover:text-accent">Pregúntale al Chasqui</a></li>
          <li><a href="/acerca" class="inline-block rounded-lg px-3 py-2 text-surface-600 transition hover:text-accent">Acerca de</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-surface-500">Elecciones 2026</h3>
        <p class="mt-3 text-sm text-surface-600">12 de abril de 2026</p>
        {days > 0 && (
          <div class="mt-3 inline-flex items-baseline gap-2 rounded-xl bg-accent-glow px-4 py-2">
            <span class="text-3xl font-extrabold text-accent">{days}</span>
            <span class="text-sm text-accent-light">días restantes</span>
          </div>
        )}
      </div>
    </div>

    <div class="mt-10 border-t border-surface-300/30 pt-5 text-center text-xs text-surface-500">
      Datos del Jurado Nacional de Elecciones (JNE). Proyecto independiente de código abierto.
    </div>
  </div>
</footer>
