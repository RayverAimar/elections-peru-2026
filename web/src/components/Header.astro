---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/candidatos', label: 'Candidatos' },
  { href: '/investiga', label: 'Investiga' },
  { href: '/eventos', label: 'Eventos' },
  { href: '/chat', label: 'Chasqui' },
  { href: '/noticias', label: 'Noticias' },
];
---

<header class="sticky top-0 z-50 border-b border-surface-300/50 bg-surface-0/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3.5" aria-label="Navegación principal">
    <a href="/" class="flex items-center gap-2.5 text-lg font-bold text-surface-900">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent">
        <span class="text-sm font-extrabold text-white">C</span>
      </div>
      <span>Chasqui</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <li>
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'relative rounded-lg px-3.5 py-2 text-sm font-medium transition-all duration-200',
                isActive ? 'text-white' : 'text-surface-600 hover:text-surface-800',
              ]}
            >
              {isActive && <span class="absolute inset-0 rounded-lg bg-surface-200" />}
              <span class="relative">{link.label}</span>
            </a>
          </li>
        );
      })}
      <li class="ml-2">
        <a href="/brujula" class="rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-accent-dark hover:shadow-lg hover:shadow-accent-glow">
          Descubre tu candidato
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger — Fix #5: min 44px touch target -->
    <button
      id="mobile-menu-btn"
      class="flex h-11 w-11 items-center justify-center rounded-lg text-surface-600 hover:bg-surface-200 hover:text-white md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu — Fix #14: animated open/close -->
  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] overflow-hidden border-t border-surface-300/50 bg-surface-50 transition-[grid-template-rows] duration-200 ease-out md:hidden"
  >
    <div class="overflow-hidden">
      <ul class="space-y-1 px-4 py-3">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          return (
            <li>
              <a
                href={link.href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'block rounded-lg px-3 py-3 text-sm font-medium transition-colors',
                  isActive ? 'bg-surface-200 text-white' : 'text-surface-600 hover:bg-surface-200 hover:text-white',
                ]}
              >
                {link.label}
              </a>
            </li>
          );
        })}
        <li class="pt-2">
          <a href="/brujula" class="block rounded-lg bg-accent px-3 py-3 text-center text-sm font-semibold text-white">
            Descubre tu candidato
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<!-- Fix #3: Re-bind after view transitions -->
<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const hamburger = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    if (!btn || !menu || !hamburger || !closeIcon) return;

    // Reset state on nav
    menu.classList.remove('grid-rows-[1fr]');
    menu.classList.add('grid-rows-[0fr]');
    hamburger.classList.remove('hidden');
    closeIcon.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.contains('grid-rows-[1fr]');
      menu.classList.toggle('grid-rows-[0fr]', isOpen);
      menu.classList.toggle('grid-rows-[1fr]', !isOpen);
      hamburger.classList.toggle('hidden', !isOpen);
      closeIcon.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
