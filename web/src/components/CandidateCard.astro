---
interface Props {
  id: number;
  name: string;
  candidate: string;
  photoUrl?: string;
}

const { id, name, candidate, photoUrl } = Astro.props;
---

<a
  href={`/candidatos/${id}`}
  class="group flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white transition hover:border-primary-300 hover:shadow-lg"
>
  <div class="flex items-center gap-4 p-4">
    <div class="h-16 w-16 flex-shrink-0 overflow-hidden rounded-full bg-slate-100">
      {photoUrl ? (
        <img
          src={photoUrl}
          alt={candidate}
          class="h-full w-full object-cover"
          loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="hidden h-full w-full items-center justify-center text-xl font-bold text-slate-400">
          {candidate.charAt(0)}
        </div>
      ) : (
        <div class="flex h-full w-full items-center justify-center text-xl font-bold text-slate-400">
          {candidate.charAt(0)}
        </div>
      )}
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="truncate text-sm font-semibold text-slate-900 group-hover:text-primary-700">
        {name}
      </h3>
      <p class="mt-0.5 truncate text-sm text-slate-600">{candidate}</p>
    </div>
    <svg class="h-5 w-5 flex-shrink-0 text-slate-400 transition group-hover:text-primary-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
