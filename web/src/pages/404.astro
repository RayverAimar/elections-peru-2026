---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada">
  <div class="flex flex-1 items-center justify-center px-4 py-24">
    <div class="text-center">
      <p class="text-7xl font-extrabold text-accent">404</p>
      <h1 class="mt-4 text-2xl font-bold text-white">Página no encontrada</h1>
      <p class="mt-2 text-surface-600">El Chasqui no encontró esta ruta.</p>
      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <a href="/" class="rounded-xl bg-accent px-6 py-3 font-semibold text-white transition hover:bg-accent-dark">
          Ir al inicio
        </a>
        <a href="/brujula" class="rounded-xl border border-surface-300/50 px-6 py-3 font-semibold text-surface-700 transition hover:bg-surface-200/50">
          Iniciar Quiz
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
