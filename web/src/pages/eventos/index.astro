---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventsFilter from '../../islands/EventsFilter.tsx';
---

<BaseLayout title="Eventos Políticos" description="30 eventos políticos clave que todo votante peruano debe conocer.">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Eventos Políticos Clave</h1>
      <p class="mt-2 text-surface-600">
        Los eventos más importantes de la política peruana reciente y cómo se posicionaron los partidos.
      </p>
    </div>

    <EventsFilter client:idle />
  </div>
</BaseLayout>
