---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventDetailView from '../../islands/EventDetailView.tsx';
---

<BaseLayout title="Evento Político" description="Detalle de evento político clave.">
  <div class="mx-auto max-w-3xl px-4 py-12">
    <nav class="mb-8 text-sm text-surface-500">
      <a href="/eventos" class="transition hover:text-accent">Eventos</a>
      <span class="mx-2 text-surface-400">/</span>
      <span class="text-surface-700">Detalle</span>
    </nav>

    <EventDetailView client:load />

    <div class="mt-10">
      <a href="/eventos" class="inline-flex items-center gap-2 text-sm font-medium text-surface-600 transition hover:text-accent">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Volver a eventos
      </a>
    </div>
  </div>
</BaseLayout>
