---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InvestigaGrid from '../../islands/InvestigaGrid.tsx';
---

<BaseLayout title="Investiga a tu candidato" description="Conoce los eventos cuestionables vinculados a cada partido político en las elecciones 2026.">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Investiga a tu candidato</h1>
      <p class="mt-2 text-surface-600">
        Eventos cuestionables en los que cada partido participó, apoyó o estuvo involucrado.
      </p>
    </div>

    <InvestigaGrid client:idle />
  </div>
</BaseLayout>
