---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsFilter from '../../islands/NewsFilter.tsx';
---

<BaseLayout title="Noticias" description="Cobertura mediática de los candidatos presidenciales con análisis de sentimiento.">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Noticias de Campaña</h1>
      <p class="mt-2 text-surface-600">
        Cobertura mediática con análisis de sentimiento.
      </p>
    </div>

    <NewsFilter client:idle />
  </div>
</BaseLayout>
