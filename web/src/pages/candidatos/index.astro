---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CandidateSearch from '../../islands/CandidateSearch.tsx';
import fs from 'node:fs';
import path from 'node:path';

const dataPath = path.resolve(process.cwd(), '../data/candidatos_2026.json');
const raw = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));

const candidates = raw.parties.map((p: any) => ({
  id: p.jne_id,
  name: p.party_name,
  candidate: p.presidential_formula.president?.full_name || 'Sin candidato',
  photoUrl: p.presidential_formula.president?.photo_url || undefined,
}));
---

<BaseLayout title="Candidatos" description="Explora los 36 partidos políticos y sus candidatos presidenciales para las Elecciones 2026.">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Candidatos Presidenciales</h1>
      <p class="mt-2 text-surface-600">
        <span class="font-semibold text-surface-700">{candidates.length}</span> partidos políticos en las Elecciones Generales 2026
      </p>
    </div>

    <CandidateSearch client:idle candidates={candidates} />
  </div>
</BaseLayout>
